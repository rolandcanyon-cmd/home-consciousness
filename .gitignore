# Runtime state — never commit these
.instar/state/
.instar/logs/
.instar/audit/
.instar/*.tmp
.instar/server-data/
.instar/imessage/
.instar/ledger/
.instar/bin/
.instar/views/
.instar/paste/
.instar/backups/
.instar/machine/
.instar/shadow-install/
.instar/secrets/
.instar/.backup-worktree/

# SQLite databases and WAL files
.instar/*.db
.instar/*.db-shm
.instar/*.db-wal
.instar/memory.db
.instar/memory.db-*

# Runtime JSON files updated by the server
.instar/feedback.json
.instar/security.jsonl
.instar/degradations.json
.instar/skill-telemetry.jsonl
.instar/imessage-messages.jsonl
.instar/imessage-poll-offset.json

# Secrets and per-machine config
.instar/config.json
.instar/context/project.dc
.instar/secrets/pr-gate/

# Machine-specific / instance-specific files
# Use setup/bootstrap.sh to regenerate for each install
.instar/AGENT.md
.instar/MEMORY.md
.claude/settings.json
.claude/settings.json.bak*
.claude/settings.local.json
.mcp.json

# Tokens and auth
.kittenkong-token.json

# Claude Code
.claude/projects/
.claude/todos/
.claude/scripts/__pycache__/
.claude/scripts/.instar/

# Playwright browser sessions
.playwright-mcp/

# Dependencies
node_modules/

# Logs
logs/

# Screenshots and test artifacts
*.png
*.jpg
test_funkygibbon.db

# Accidental files
*T*:*:*.???Z
