{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .instar/hooks/instar/dangerous-command-guard.sh \"$TOOL_INPUT\"",
            "blocking": true
          },
          {
            "type": "command",
            "command": "bash .instar/hooks/instar/grounding-before-messaging.sh \"$TOOL_INPUT\"",
            "blocking": false
          },
          {
            "type": "command",
            "command": "node /Users/rolandcanyon/.instar/agents/Roland/.instar/hooks/instar/deferral-detector.js",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "node /Users/rolandcanyon/.instar/agents/Roland/.instar/hooks/instar/external-communication-guard.js",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "node /Users/rolandcanyon/.instar/agents/Roland/.instar/hooks/instar/post-action-reflection.js",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/rolandcanyon/.instar/agents/Roland/.instar/hooks/instar/external-operation-gate.js",
            "blocking": true,
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash .instar/hooks/instar/session-start.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash .instar/hooks/instar/session-start.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash .instar/hooks/instar/session-start.sh",
            "timeout": 5
          }
        ]
      }
    ],
